{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "isolatedModules": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.vue", "vite.config.ts"]
}
