{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "isolatedModules": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client", "node"],
        "skipLibCheck": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
